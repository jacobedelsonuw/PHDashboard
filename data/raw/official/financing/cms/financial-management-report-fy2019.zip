  <!-- Custom Scripts -->
  <script>
    (function($) {
      $(document).ready(function($) {
        // CMS USA banner toggle
        $(document).on("click",'.ds-c-usa-banner__button',function() {
          let $input = $("#gov-banner_1");
          let attr = $input.attr('hidden');

          if (typeof attr !== typeof undefined && attr !== false) {
            $input.removeAttr("hidden");
            $(this).attr("aria-expanded",true);
            $(".ds-c-usa-banner__header").addClass('ds-c-usa-banner__header--expanded');
          } else {
            $input.attr("hidden", '');
            $(this).attr("aria-expanded",false);
            $(".ds-c-usa-banner__header").removeClass('ds-c-usa-banner__header--expanded');
          }
          return false;
        });
  </script>
  
   <script>
    (function($) {
      $(document).ready(function($) {
        // CMS USA banner toggle
        $(document).on("click",'.ds-c-usa-banner__button',function() {
          let $input = $("#gov-banner_1");
          let attr = $input.attr('hidden');

          if (typeof attr !== typeof undefined && attr !== false) {
            $input.removeAttr("hidden");
            $(this).attr("aria-expanded",true);
            $(".ds-c-usa-banner__header").addClass('ds-c-usa-banner__header--expanded');
          } else {
            $input.attr("hidden", '');
            $(this).attr("aria-expanded",false);
            $(".ds-c-usa-banner__header").removeClass('ds-c-usa-banner__header--expanded');
          }
          return false;
        });

        // Back to top button
        var amountScrolled = 200;

        // Initially hide the button
        $('a.back-to-top').hide();

        $(window).scroll(function() {
          if ($(window).scrollTop() > amountScrolled) {
            $('a.back-to-top').fadeIn('slow');
          } else {
            $('a.back-to-top').fadeOut('slow');
          }
        });

        $('a.back-to-top').click(function() {
          $('html, body').animate({
            scrollTop: 0
          }, 700);
          return false;
        });
      });
    })(jQuery);
  </script>
