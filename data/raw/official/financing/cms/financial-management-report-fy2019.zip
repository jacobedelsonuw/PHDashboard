<!DOCTYPE html>
<html lang="en-us">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">
  <title>Error: Page Not Found | Medicaid.gov</title>
  <link type="image/ico" href="https://www.medicaid.gov/themes/custom/medicaid/images/favicons/favicon-57.png" rel="icon">
  <meta name="description" content="This page appears when the page someone is searching for does not exist"/>
  
  <!-- Font Awesome -->
  <link media="all" rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.3.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.0.4/css/all.min.css">
  
  <!-- Main Styles -->
  <link media="all" rel="stylesheet" type="text/css" href="https://www.medicaid.gov/themes/custom/medicaid/css/main.css">
  <link rel="stylesheet" type="text/css" href="https://www.medicaid.gov/themes/custom/medicaid/css/uswds.css">
  
  <!-- jQuery -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/1.11.3/jquery.min.js"></script>

  <style>
    /* Banner styling */
    .ds-c-usa-banner__header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .ds-c-usa-banner__header-text {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0;
      font-size: 1.5rem;
    }
    
    .ds-c-usa-banner__header-flag {
      display: inline-block;
      margin-right: 0.5rem;
    }

    .ds-c-usa-banner{
      background-color: #f0f0f0;
      padding-top: 0.1rem;
      padding-bottom: 0.1rem;
    }

    a.site-branding__logo img {
      width:302px;
    }

    .usa-nav-secondary {
        margin-top: 1.8rem;
    }

    /* Footer column layout */
    .usa-footer-nav {
      display: flex;
      flex-wrap: wrap;
      width: 75%;
      float: left;
    }

    .footer-left-column {
      width: 30%;
      float: left;
    }

    .footer-left-column li {
      display: inline-block;
      width: 48%;
      vertical-align: top;
    }

    .footer-left-column li.usa-footer-primary-link {
      display: block;
      width: 100%;
      margin-bottom: 1rem;
    }

    .footer-left-column li a {
      display: inline-block;
      margin-bottom: 0.5rem;
    }

    .footer-middle-column {
      width: 70%;
      float: left;
      padding-left: 3rem;
    }

    .footer-email {
      margin-top: 0px;
    }

    .usa-footer .usa-footer-primary-link ~ li a {
      text-decoration: underline;
    }

    .footer-middle-column .helpful-links-wrapper {
      display: inline-block;
      width: 47%;
      vertical-align: top;
      margin-bottom: 0.5rem;
    }

    .usa-sign_up-block {
      width: 25%;
      float: left;
      padding-left: 3rem;
    }

    @media screen and (max-width: 950px) {
      .footer-left-column,
      .footer-middle-column,
      .usa-sign_up-block {
        width: 100%;
        float: none;
        padding-left: 0;
      }

      .footer-middle-column .helpful-links-wrapper {
        width: 100%;
      }
    }
    
    @media screen and (min-width: 1201px) {
      .footer-left-column li:nth-of-type(even).usa-footer-secondary-link, .footer-middle-column li:nth-of-type(even).usa-footer-secondary-link {
        margin-right: 2rem;
      }
    }

    @media (min-width: 951px) {
      .footer-left-column li:nth-of-type(even).usa-footer-secondary-link {
        width: 150px;
        float: left;
      }

      .footer-middle-column li:nth-of-type(even).usa-footer-secondary-link.width-fix {
        width: 150px;
        float: left;
      }
    }

    #pageContent {
      margin-bottom: 60px;
    }

    h2 {
      margin-top:35px;
    }
    .clear {
      clear:both;
    }
    .column {
      float: left;
      width: 33%;
      padding: 0 10px;
      flex:1;
    }

    .row {
      margin: 0 -5px;
      display: flex;
    }

    .row:after {
      content: "";
      display: table;
      clear: both;
    }

    @media screen and (max-width: 600px) {
      .column {
        width: 100%;
        display: block;
        margin-bottom: 20px;
      }
      .row {
        display: block;
      }
    }

    .card {
      box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
      padding: 16px;
      background-color: #f1f1f1;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .usa-button {
      margin-top:auto;
    }

    .usa-sign_up-block form {
      padding-top:15px;
    }

    .usa-sign_up-block input#email {
      margin-top:15px;
      margin-bottom: 15px;
    }

    .usa-footer-primary-content.footer-middle-column:last-child {
      padding-left: 5%;
    }
    .usa-sign_up-block label {
      margin-top:0px;
    }

    .usa-sign_up-block  .usa-footer-primary-link {
      margin-bottom:0px;
      padding-bottom:0px
    }

    .svg-inline--fa.fa-youtube.fa-w-18.fa-lg {
      width: 38px;
      height: 22px;
    }

    .ds-u-display--flex.ds-u-flex-direction--column.ds-u-sm-flex-direction--row.ds-u-flex-wrap--nowrap {
      margin-top: 2rem;
    }

    .ds-c-usa-banner__icon {
        float: left;

    }
    .ds-c-usa-banner__media-body {
        margin-left: 6rem;
        margin-top: 0rem;
        margin-bottom:1rem;

    }
    .ds-c-usa-banner__icon {
        width: 40px;

    }
    .ds-c-usa-banner__lock-image {
      width: 12px;
    }


    .ds-c-usa-banner__guidance {
      width: 45%;
      float: left;
      padding-left: 2rem;  
    }
    /* =========================================================
   External Link Icons — exclude internal, mailto, tel, and social
   ========================================================= */
a[href]:not(:where(
  /* exclude hash-only links */
  [href^="#"],
  /* exclude javascript only links */
  [href^="javascript:" i],
  /* exclude relative but not protocol-relative links */
  [href^="/"]:not([href^="//"]),
  /* exclude internal domains */
  [href*="medicaid.gov"],
  /* exclude email and phone links */
  [href^="mailto:"],
  [href^="tel:"],
  /* exclude query-only links */
  [href^="?"],
  /* exclude language toggle */
  [class="en-espanol"],
  /* exclude social media and video platforms */
  [href*="twitter.com"],
  [href*="youtube.com"],
  [href*="facebook.com"],
  [href*="instagram.com"],
  [href*="linkedin.com"],
  [href*="x.com"],
  [href*="index.html"]
))::after {
  content: "";
  display: inline-block;
  width: 1.75ex;
  height: 1.75ex;
  margin-left: 2px;
  vertical-align: middle;
  background-color: #046791;
  mask: url("https://www.insurekidsnow.gov/themes/custom/medicaid/uswds/img/usa-icons/launch.svg") no-repeat center;
  -webkit-mask: url("https://www.insurekidsnow.gov/themes/custom/medicaid/uswds/img/usa-icons/launch.svg") no-repeat center;
  mask-size: contain;
  -webkit-mask-size: contain;
}

/* Mailto (Email) Links — add mail icon*/
a[href^="mailto:"]::after {
  content: "";
  display: inline-block;
  width: 1.75ex;
  height: 1.75ex;
  margin-left: 2px;
  vertical-align: middle;
  background-color: #046791;
  mask: url("https://www.insurekidsnow.gov/themes/custom/medicaid/uswds/img/usa-icons/mail_outline.svg") no-repeat center;
  -webkit-mask: url("https://www.insurekidsnow.gov/themes/custom/medicaid/uswds/img/usa-icons/mail_outline.svg") no-repeat center;
  mask-size: contain;
  -webkit-mask-size: contain;
}


/* Remove icons for social media links */
.usa-footer-contact-links a.usa-link-youtube::after,
.usa-link-twitter::after,
.usa-link-facebook::after,
.usa-link-instagram::after,
.usa-link-linkedin::after,
.remove-external-link-icon::after {
  content: none !important;
  display: none !important;
}

/* “X” / Twitter brand styling*/
.x-link::after {
  content: none !important;
  display: none !important;
}

.x-link:hover svg {
  color: #1DA1F2; /* X brand blue */
}

/* Social link spacing tweaks*/
.usa-social_link,
.usa-link-facebook,
.usa-link-twitter,
.usa-link-youtube,
.usa-link-rss {
  margin: 0 0 0 0.5rem;
  left: 0.3rem;
}

  </style>
</head>
